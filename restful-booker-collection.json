      "name": "Booking - Read",
      "item": [
        {
          "name": "Get All Bookings",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200 OK\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response is an array\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData).to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Array is not empty\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.length).to.be.above(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Each item has bookingid\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    jsonData.forEach(function(booking) {\r",
                  "        pm.expect(booking).to.have.property(\"bookingid\");\r",
                  "    });\r",
                  "    \r",
                  "    // Save first bookingid for next requests\r",
                  "    pm.environment.set(\"booking_id\", jsonData[0].bookingid);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
